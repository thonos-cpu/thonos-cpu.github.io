---
import { getGitHubData } from '../lib/github';

const data = await getGitHubData();
const top = data.stats.languages.slice(0, 6);
const restPct = data.stats.languages.slice(6).reduce((a, l) => a + l.pct, 0);

// Stable, palette-aligned hues per language band.
const HUES = [188, 215, 32, 270, 150, 0];
const fmtPct = (p: number) => (p < 1 ? '<1' : Math.round(p)) + '%';
---

<section id="stack" class="section skills" data-section="stack">
  <div class="container">
    <div class="section-head">
      <span class="section-index">04</span>
      <h2 class="section-title">Stack &amp; signals</h2>
      <p class="section-note">
        The real language mix, measured live across every public repository.
      </p>
    </div>

    <div class="skills__live" data-reveal>
      <div class="skills__live-head">
        <span class="eyebrow">Language distribution · live from GitHub</span>
        <span class="mono dim">{data.stats.totalRepos} repositories</span>
      </div>
      <div
        class="skills__bar"
        role="img"
        aria-label="Distribution of programming languages across all repositories"
      >
        {
          top.map((l, i) => (
            <span
              class="skills__seg"
              style={`width:${l.pct}%;--h:${HUES[i % HUES.length]}`}
              title={`${l.name} · ${fmtPct(l.pct)}`}
            />
          ))
        }
        {restPct > 0 && <span class="skills__seg skills__seg--rest" style={`width:${restPct}%`} />}
      </div>
      <ul class="skills__legend">
        {
          top.map((l, i) => (
            <li class="mono">
              <span
                class="skills__swatch"
                style={`--h:${HUES[i % HUES.length]}`}
                aria-hidden="true"
              />
              {l.name}
              <span class="dim">{fmtPct(l.pct)}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .skills__live {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.4rem, 3vw, 2rem);
    background: var(--surface);
  }
  .skills__live-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .skills__bar {
    display: flex;
    height: 12px;
    border-radius: 999px;
    overflow: hidden;
    background: var(--bg-soft);
    gap: 2px;
  }
  .skills__seg {
    height: 100%;
    background: hsl(var(--h) 60% 60%);
    border-radius: 2px;
    transition:
      filter 0.3s var(--ease),
      transform 0.3s var(--ease);
    transform-origin: bottom;
  }
  .skills__seg:hover {
    filter: brightness(1.2);
    transform: scaleY(1.25);
  }
  .skills__seg--rest {
    background: var(--text-faint);
  }
  .skills__legend {
    list-style: none;
    padding: 0;
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.4rem;
    font-size: 0.74rem;
  }
  .skills__legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .skills__legend .dim {
    margin-left: 0.15rem;
  }
  .skills__swatch {
    width: 9px;
    height: 9px;
    border-radius: 2px;
    background: hsl(var(--h) 60% 60%);
  }
</style>
