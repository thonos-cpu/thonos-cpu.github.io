# Copy to .env for local development. None of this is required to run the site,
# but a token avoids the 60-requests/hour unauthenticated GitHub API limit.

# A GitHub fine-grained or classic token with public read access.
# Lifts the build-time API limit from 60/h to ~5000/h.
GITHUB_TOKEN=

# Only needed if you run scripts/weekly-report.mjs locally.
GOATCOUNTER_CODE=thonos
GOATCOUNTER_API_TOKEN=
