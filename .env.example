# Browser-safe Vercel / local Next.js variables
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
NEXT_PUBLIC_ANALYTICS_ENABLED=true
GITHUB_TOKEN=

# Vercel server-only variables. Never prefix these with NEXT_PUBLIC_:
SUPABASE_SECRET_KEY=
ANALYTICS_HASH_SALT=
ANALYTICS_ENCRYPTION_KEY=
ANALYTICS_RETENTION_DAYS=730
SENSITIVE_LOG_RETENTION_DAYS=30
VERCEL_SANDBOX_SNAPSHOT_ID=

# GitHub Actions secrets. Configure in GitHub, never in this file:
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
