# Optional authenticated GitHub requests (server-only, never prefix with NEXT_PUBLIC_)
GITHUB_TOKEN=

# Vercel AI Gateway uses OIDC automatically in production.
# For local development, run `vercel env pull` or provide an AI Gateway key.
AI_GATEWAY_API_KEY=
THANOSGPT_MODEL=openai/gpt-5.4

# Optional Cloudflare Turnstile. If omitted, local development remains usable.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Self-host Piston for production; the public endpoint is a development fallback.
PISTON_API_URL=https://emkc.org/api/v2/piston

# Historical first-party analytics (server-only except the enable flag).
NEXT_PUBLIC_ANALYTICS_ENABLED=false
DATABASE_URL=
ANALYTICS_HASH_SALT=
ANALYTICS_ENCRYPTION_KEY=
ANALYTICS_RETENTION_DAYS=730
SENSITIVE_LOG_RETENTION_DAYS=30
# Local visual preview only; ignored on production deployments.
ANALYTICS_DEMO_MODE=false

# Private dashboard authentication. Generate values with:
# ADMIN_PASSWORD="choose-a-strong-password" npm run admin:secrets
ADMIN_USERNAME=athanasios
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
