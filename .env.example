# Vercel / local Next.js build variables
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
GITHUB_TOKEN=

# Supabase Edge Function secrets — do not place these in NEXT_PUBLIC_* values:
# OPENAI_API_KEY=
# THANOSGPT_MODEL=gpt-5.4
# TURNSTILE_SECRET_KEY=
# PISTON_API_URL=https://emkc.org/api/v2/piston
# ANALYTICS_HASH_SALT=
# ANALYTICS_ENCRYPTION_KEY=
# ANALYTICS_RETENTION_DAYS=730
# SENSITIVE_LOG_RETENTION_DAYS=30
# ALLOWED_ORIGINS=https://tasis.info,https://www.tasis.info,http://localhost:3000,http://127.0.0.1:3000
# ALLOWED_ORIGIN_SUFFIXES=.vercel.app

# GitHub Actions secrets — configure in GitHub, never in this file:
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
